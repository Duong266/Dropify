<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Dropify"
            app:titleTextColor="@color/text_primary" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_dark"
            app:tabIndicatorColor="@color/color_primary"
            app:tabSelectedTextColor="@color/color_primary"
            app:tabTextColor="@color/text_secondary"
            app:tabMode="scrollable"
            app:tabMinWidth="120dp" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutMiniPlayer"
        android:layout_below="@id/appBarLayout" />

    <RelativeLayout
        android:id="@+id/layoutMiniPlayer"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_mini_player"
        android:elevation="8dp"
        android:padding="8dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMiniArt"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_centerVertical="true"
            app:cardCornerRadius="32dp">

            <ImageView
                android:id="@+id/imgMiniAlbumArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_default_cd" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:layout_toEndOf="@id/cardMiniArt"
            android:layout_toStartOf="@id/btnMiniPlayPause"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvMiniSong"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:marqueeRepeatLimit="marquee_forever"
                android:singleLine="true"
                android:text="Tên bài hát"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMiniArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:text="Tên nghệ sĩ"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnMiniPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_play" />
    </RelativeLayout>

    <include
        android:id="@+id/includeAlbumDetail"
        layout="@layout/layout_album_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/layoutPlayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="0dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnCollapse"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_down"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:layout_marginStart="8dp"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnPlayerOptions"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_more_vert"
                android:scaleType="fitCenter"
                android:padding="12dp"
                app:tint="@color/text_primary" />
        </RelativeLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/playerViewPager"
            android:layout_width="match_parent"
            android:layout_height="380dp" />

        <!-- Phần thông tin và điều khiển cố định -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@+id/btnAddToPlaylistPlayer"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCurrentSongPlayer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên bài hát"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="marquee"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:scrollHorizontally="true"
                    android:singleLine="true" />

                <TextView
                    android:id="@+id/tvCurrentArtistPlayer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tên nghệ sĩ"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnAddToPlaylistPlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_toStartOf="@+id/btnFavoritePlayer"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_queue_music"
                android:padding="10dp"
                android:scaleType="fitCenter"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnFavoritePlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_heart_off"
                android:padding="10dp"
                android:scaleType="fitCenter"
                app:tint="@color/text_primary" />
        </RelativeLayout>

        <SeekBar
            android:id="@+id/seekBarPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:progressTint="@color/color_primary"
            android:thumbTint="@color/color_primary" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="32dp"
            android:paddingEnd="32dp">

            <TextView
                android:id="@+id/tvCurrentTimePlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvTotalTimePlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnShufflePlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_shuffle_off"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnPrevPlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnPlayPausePlayer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_play_pause"
                android:src="@android:drawable/ic_media_play"
                android:padding="20dp"
                android:scaleType="fitCenter"
                app:tint="@color/bg_dark" />

            <ImageButton
                android:id="@+id/btnNextPlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/btnRepeatPlayer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_repeat_none"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/divider_color" />

    <TextView
        android:id="@+id/tvTrimTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cắt nhạc"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:ellipsize="end"
        android:singleLine="true"/>

    <TextView
        android:id="@+id/tvTrimRange"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đoạn cắt: 00:00 - 00:00"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.slider.RangeSlider
        android:id="@+id/trimRangeSlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:values="@array/initial_range_values"
        app:thumbColor="@color/color_primary"
        app:trackColorActive="@color/color_primary"
        app:trackColorInactive="@color/divider_color"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnStartTrim"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Bắt đầu cắt"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        android:backgroundTint="@color/color_primary"
        android:textColor="@color/bg_dark"
        android:textStyle="bold"/>
</LinearLayout>
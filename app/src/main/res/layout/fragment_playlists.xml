<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top 4 boxes -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2">

            <!-- Most Played -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardMostPlayed"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="8dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_cd"
                        android:alpha="0.6" />
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#80000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|top"
                        android:layout_margin="12dp"
                        android:text="Được phát nhiều nhất"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvMostPlayedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|bottom"
                        android:layout_margin="12dp"
                        android:text="0 Bài hát"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:layout_margin="12dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Last Added -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardLastAdded"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="8dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_cd"
                        android:alpha="0.6" />
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#80000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|top"
                        android:layout_margin="12dp"
                        android:text="Được thêm sau cùng"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvLastAddedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|bottom"
                        android:layout_margin="12dp"
                        android:text="0 Bài hát"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:layout_margin="12dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recently Played -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardRecentlyPlayed"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="8dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_cd"
                        android:alpha="0.6" />
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#80000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|top"
                        android:layout_margin="12dp"
                        android:text="Phát gần đây"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvRecentlyPlayedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|bottom"
                        android:layout_margin="12dp"
                        android:text="0 Bài hát"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:layout_margin="12dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <!-- Favorites -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFavorites"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_rowWeight="1"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="8dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_default_cd"
                        android:alpha="0.6" />
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#80000000" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|top"
                        android:layout_margin="12dp"
                        android:text="Yêu thích"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvFavoritesCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start|bottom"
                        android:layout_margin="12dp"
                        android:text="0 Bài hát"
                        android:textColor="#CCCCCC"
                        android:textSize="12sp" />
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="end|bottom"
                        android:layout_margin="12dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </GridLayout>

        <!-- Playlist Section Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PLAYLIST"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnAddPlaylist"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layoutEmptyPlaylist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="32dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_default_cd"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Không có danh sách nhạc"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCreatePlaylist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Tạo danh sách"
                app:icon="@android:drawable/ic_input_add"
                android:backgroundTint="@color/color_primary"
                android:textColor="@color/background_dark" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRestorePlaylist"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Khôi phục lại danh sách phát"
                app:icon="@android:drawable/ic_menu_recent_history"
                android:textColor="@color/color_primary"
                app:strokeColor="@color/color_primary" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPlaylists"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>